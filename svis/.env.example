# Semantic Visual Intelligence System — Environment Variables
# Copy this file to .env and fill in your values.
# At least one LLM key is recommended for advanced mode.

# ── LLM API Keys (choose one or both) ─────────────────────────
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (free tier available) — https://console.groq.com/keys
GROQ_API_KEY=

# ── Optional Settings ──────────────────────────────────────────
# Set to "cuda" to force GPU, "cpu" to force CPU, or leave blank for auto-detect
DEVICE=

# Hugging Face token (needed only for gated models)
HUGGINGFACE_TOKEN=
